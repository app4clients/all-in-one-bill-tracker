PORT=4000
CORS_ORIGIN=http://localhost:5173

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bill_tracker
DATABASE_SSL=false

# Google Play Billing verification
GP_PACKAGE_NAME=com.app4clients.allinonebilltracker
GP_PRODUCT_MONTHLY=premium_monthly
GP_PRODUCT_YEARLY=premium_yearly
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./service-account.json

# Optional: protect RTDN endpoint with a shared header value.
RTDN_SHARED_SECRET=

# Auth (signup/login)
AUTH_JWT_SECRET=replace_with_long_random_secret
AUTH_JWT_EXPIRES_IN=30d
# Password reset flow
# For production keep AUTH_EXPOSE_RESET_TOKEN=false and deliver token through email/SMS provider.
AUTH_PASSWORD_RESET_TTL_MINUTES=15
AUTH_EXPOSE_RESET_TOKEN=false
# Resend email delivery (required for real reset code emails)
RESEND_API_KEY=
RESEND_FROM_EMAIL=All-in-One Bill Tracker <noreply@yourdomain.com>
APP_DISPLAY_NAME=All-in-One Bill Tracker
# Optional admin-managed username moderation list (comma-separated)
# Example: sex,porn,xxx,nude,adult,escort
BLOCKED_USERNAME_WORDS=sex,porn,xxx,nude,adult,escort,camgirl,onlyfans
# Optional allow-list override for legitimate usernames that may match blocked terms.
# Example: sexton,essex_team
ALLOWED_USERNAME_WHITELIST=

# Optional admin key for reading auth rejection logs
ADMIN_API_KEY=
